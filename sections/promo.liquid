{{ 'promo.css' | asset_url | stylesheet_tag }}

<section id="promo-section" class="promo" role="region" aria-label="Promotional banner">
  <div class="promo__inner">
    <picture class="promo__media">
      <img src="{{ 'promo-image.jpg' | asset_url }}" width="800" height="400" loading="lazy" alt="20% off select smart TVs and home electronics" />
    </picture>

    <div class="promo__body">
      <h2 class="promo__title">Spring Electronics Sale</h2>
      <p class="promo__text">Upgrade your home with selected smart TVs, speakers, and more.</p>

      <div class="promo__actions">
        <a class="promo__link" href="/collections/sale">Explore the sale collection</a>
        <button class="promo__cta" type="button" aria-label="Shop smart TVs" id="promo-cta">Shop smart TVs</button>
      </div>

      <form id="promo-form" class="promo__form" action="/contact" method="post" aria-labelledby="promo-form-label">
        <div>
          <label id="promo-form-label" for="promo-email">Subscribe for promotion updates</label>
          <input id="promo-email" name="contact[email]" type="email" placeholder="you@example.com" required />
        </div>
        <button type="submit" aria-label="Subscribe to promotion updates">Subscribe</button>
      </form>
    </div>
  </div>

  <script defer src="{{ 'heavy-lib.js' | asset_url }}"></script>
  <script defer src="{{ 'promo.js' | asset_url }}"></script>
</section>

{% schema %}
{
  "name": "Promo section",
  "settings": [],
  "blocks": [],
  "presets": [{ "name": "Promo" }]
}
{% endschema %}
